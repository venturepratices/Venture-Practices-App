// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AGENCY
  CLIENT // reserved for Phase 2 (client logins); unused in Phase 1, everyone defaults to AGENCY
}

enum ClientStatus {
  ACTIVE
  ONBOARDING
  PAUSED
  OFFBOARDED
}

enum TaskOccurrence {
  RECURRING_WEEKLY
  RECURRING_MONTHLY
  RECURRING_QUARTERLY
  PROJECT
  NON_RECURRING
}

enum TaskStatus {
  ACTIVE
  IN_PROGRESS
  PRIORITY
  NEXT_UP
  WAITING_ON_CLIENT
  ON_HOLD
  COMPLETE
}

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(AGENCY)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  assignedTasks Task[]         @relation("TaskAssignee")
  archivedTasks ArchivedTask[] @relation("ArchivedBy")
}

// Auth.js required models for the Prisma adapter (database session strategy)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user TeamMember @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user TeamMember @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id        String       @id @default(cuid())
  name      String
  status    ClientStatus @default(ONBOARDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tasks Task[]
}

model Task {
  id         String         @id @default(cuid())
  title      String
  assigneeId String?
  assignee   TeamMember?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  clientId   String? // null = internal/agency task, not tied to a client
  client     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  occurrence TaskOccurrence @default(NON_RECURRING)
  status     TaskStatus     @default(NEXT_UP)
  deadline   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([clientId])
  @@index([assigneeId])
  @@index([status])
}

// Full snapshot of a Task at delete time. Denormalized on purpose (assigneeName/
// clientName as plain strings, not just FK ids) so a record stays meaningful even
// if the Client or TeamMember it referenced is later changed/deleted, and even
// read independent of the live relational DB (see archive durability mechanism
// in src/lib/archive.ts, which also mirrors this snapshot to Vercel Blob).
model ArchivedTask {
  id             String   @id @default(cuid())
  originalTaskId String
  title          String
  assigneeId     String?
  assigneeName   String?
  clientId       String?
  clientName     String?
  occurrence     TaskOccurrence
  status         TaskStatus
  deadline       DateTime?
  taskCreatedAt  DateTime
  taskUpdatedAt  DateTime
  deletedAt      DateTime @default(now())
  deletedById    String?
  deletedBy      TeamMember? @relation("ArchivedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([originalTaskId])
}
