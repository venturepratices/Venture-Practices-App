// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AGENCY
  CLIENT // reserved for Phase 2 (client logins); unused in Phase 1, everyone defaults to AGENCY
}

enum ClientStatus {
  ACTIVE
  ONBOARDING
  PAUSED
  OFFBOARDED
}

enum TaskOccurrence {
  RECURRING_WEEKLY
  RECURRING_MONTHLY
  RECURRING_QUARTERLY
  PROJECT
  NON_RECURRING
}

enum TaskStatus {
  ACTIVE
  IN_PROGRESS
  PRIORITY
  NEXT_UP
  WAITING_ON_CLIENT
  ON_HOLD
  COMPLETE
}

enum LandingPageStatus {
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  LIVE
  ARCHIVED
}

enum MeetingNoteSource {
  MANUAL
  FATHOM_WEBHOOK // reserved for when Fathom API/webhook access is confirmed; not wired up yet
}

enum NotificationType {
  ASSIGNED
  MENTIONED
  STATUS_CHANGED
  DEADLINE_CHANGED
  COMMENTED
  ASSET_UPLOADED
  ASSET_COMMENTED
  ASSET_DECIDED
  ASSET_APPROVED
  ASSET_CHANGES_REQUESTED
  ASSET_DUE_SOON
}

// Asset Approval (Phase 2) — see "Feature: Asset Approval prototype" in the plan file.
enum AssetStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  CHANGES_REQUESTED
  ARCHIVED
}

enum AssetKind {
  IMAGE
  VIDEO
  PDF
  WEBSITE // externalUrl points at a page/landing page; no file bytes stored
  OTHER
}

enum AssetDecisionValue {
  APPROVED
  APPROVED_WITH_CHANGES
  CHANGES_REQUESTED
}

model TeamMember {
  id                 String  @id @default(cuid())
  name               String
  email              String  @unique
  passwordHash       String
  // True when an admin has just set this person's password for them (a
  // temporary/recovery password) — forces them to /change-password on their
  // next login before they can do anything else. Cleared once they set their
  // own new password.
  mustChangePassword Boolean @default(false)
  role               Role    @default(AGENCY)
  // Access control. Admins bypass every check below (full access + team/
  // permission management + granting others admin/permissions). Members are
  // gated by these granular per-feature flags + the ClientAccess join (WHICH
  // clients, a separate axis from WHAT actions). Enforced fresh-from-DB per
  // request via src/lib/permissions.ts, NOT baked into the JWT — so revoking
  // access takes effect immediately. Deliberately NOT auto-granted on create —
  // an admin checks exactly the boxes they want each person to have, every time.
  isAdmin            Boolean @default(false)
  allClientsAccess   Boolean @default(false) // Member sees every client without a per-client ClientAccess row

  // Clients
  canCreateClients Boolean @default(false)
  canEditClients   Boolean @default(false)
  canDeleteClients Boolean @default(false) // no delete-client feature exists yet; reserved for when it does

  // Tasks
  canCreateTasks     Boolean @default(false)
  canEditTasks       Boolean @default(false)
  canDeleteTasks     Boolean @default(false) // archives a task
  canCommentOnTasks  Boolean @default(false)
  canManageTaskLinks Boolean @default(false)

  // Client Notes
  canCreateClientNotes Boolean @default(false)
  canEditClientNotes   Boolean @default(false)
  canDeleteClientNotes Boolean @default(false)

  // Meeting Notes
  canCreateMeetingNotes Boolean @default(false)
  canDeleteMeetingNotes Boolean @default(false)

  // Client Links (quick-access links on a client's Info tab)
  canManageClientLinks Boolean @default(false)

  // Credentials vault — viewing the list, managing entries, and revealing a
  // password are three separate, increasingly sensitive permissions. Reveal
  // also always requires re-entering the viewer's own account password.
  canViewCredentials   Boolean @default(false)
  canManageCredentials Boolean @default(false)
  canRevealCredentials Boolean @default(false)

  // HighLevel Conversations & Calls — viewing vs. connecting/managing the
  // integration (which can incur real cost/changes on HighLevel's side).
  canViewConversations Boolean @default(false)
  canManageHighLevel   Boolean @default(false)

  // Activity log & Archive
  canViewActivity   Boolean @default(false)
  canViewArchive    Boolean @default(false)
  canRestoreArchive Boolean @default(false)

  // Asset Approval (Phase 2). View is the base; upload/comment/decide are the
  // day-to-day work; manage-reviewers/share-externally/delete are more sensitive.
  canViewAssets            Boolean @default(false)
  canUploadAssets          Boolean @default(false)
  canCommentOnAssets       Boolean @default(false)
  canDecideOnAssets        Boolean @default(false)
  canManageAssetReviewers  Boolean @default(false)
  canShareAssetsExternally Boolean @default(false)
  canDeleteAssets          Boolean @default(false)
  canManageClientUsers     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions               Session[]
  accounts               Account[]
  assignedTasks          Task[]           @relation("TaskAssignee")
  archivedTasks          ArchivedTask[]   @relation("ArchivedBy")
  comments               Comment[]
  clientNotes            ClientNote[]
  meetingNotes           MeetingNote[]
  activityLogs           ActivityLog[]
  notifications          Notification[]
  clientAccess           ClientAccess[]
  createdAssets          Asset[]          @relation("AssetCreatedBy")
  uploadedAssetVersions  AssetVersion[]   @relation("AssetVersionUploadedBy")
  assetReviewerRoles     AssetReviewer[]  @relation("AssetReviewer")
  createdAssetShareLinks AssetShareLink[] @relation("AssetShareLinkCreatedBy")
}

// Per-Member grant of access to a specific Client (the "checklist of access").
// Admins and Members with allClientsAccess ignore this table entirely. Cascade
// on both sides so removing a member or client cleans up its grants.
model ClientAccess {
  id           String     @id @default(cuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, clientId])
  @@index([teamMemberId])
  @@index([clientId])
}

// Auth.js required models for the Prisma adapter (database session strategy)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user TeamMember @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user TeamMember @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id        String       @id @default(cuid())
  name      String
  status    ClientStatus @default(ONBOARDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Contact + business basics. All optional — existing clients have none of
  // this yet, and it's filled in over time, not required up front.
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  address      String?
  about        String? @db.Text

  tasks                Task[]
  notes                ClientNote[]
  meetingNotes         MeetingNote[]
  landingPages         LandingPage[]
  links                ClientLink[]
  credentials          ClientCredential[]
  highLevelConnection  ClientHighLevelConnection?
  conversationMessages ConversationMessage[]
  clientAccess         ClientAccess[]
  assets               Asset[]
  assetFolders         AssetFolder[]
  clientUsers          ClientUser[]
}

// A real login account for a client contact — distinct from TeamMember (a
// different kind of user with a different, much narrower scope: only their
// own client's non-draft assets, enforced in src/lib/permissions.ts via
// requireClientUserSession(), never through the agency capability catalog).
// Kept in its own table rather than folded into TeamMember so client-portal
// auth stays structurally separate from agency auth — mirrors the same
// "keep the boundary explicit" choice made for guest share-link sessions.
model ClientUser {
  id                 String   @id @default(cuid())
  clientId           String
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name               String
  email              String   @unique
  passwordHash       String
  // Same meaning as TeamMember.mustChangePassword — set when an admin issues
  // a temporary password; forces a self-service change on next login.
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assetReviewerRoles AssetReviewer[] @relation("AssetReviewerClientUser")

  @@index([clientId])
}

// Quick-access links to client-related sites (their website, ad accounts, GBP
// listing, etc.) — mirrors TaskLink exactly, just attached to a Client.
model ClientLink {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())

  @@index([clientId])
}

// Third-party access credentials for a client (e.g. WordPress admin login).
// encryptedPassword is ciphertext produced by src/lib/credential-crypto.ts —
// never store or log the plaintext. Revealing it requires re-entering your
// own account password (see /api/client-credentials/[credentialId]/reveal),
// which is what makes each reveal traceable to a specific person.
model ClientCredential {
  id                String   @id @default(cuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label             String
  url               String?
  username          String?
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientId])
}

// Links one of our Clients to its HighLevel (LeadConnector) sub-account so we can
// pull that client's conversations. One connection per client (@unique). The
// Private Integration Token is stored encrypted via src/lib/credential-crypto.ts
// (same AES-256-GCM helper as ClientCredential) and used server-side to call the
// HighLevel API — it is never revealed to a human, so it lives here rather than in
// the human-reveal-gated ClientCredential vault. webhookSecret is minted now but
// unused in v1 (polling via sync-on-view); it's the ready seam for a future
// instant-webhook path. See "HighLevel Conversations integration" in the plan.
model ClientHighLevelConnection {
  id             String    @id @default(cuid())
  clientId       String    @unique
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  locationId     String // HighLevel sub-account (Location) ID
  encryptedToken String // Private Integration Token, ciphertext only — never plaintext
  webhookSecret  String? // reserved for the future instant-webhook path; unused in v1
  connectedAt    DateTime  @default(now())
  lastSyncAt     DateTime? // throttles sync-on-view and records the last successful pull
  updatedAt      DateTime  @updatedAt
}

// A lean local CACHE of HighLevel conversation messages (SMS/Email/Call) for a
// client. HighLevel remains the system of record — this table is pruned on every
// sync (RETENTION_DAYS / MAX_MESSAGES_PER_CLIENT in src/lib/highlevel.ts) so it
// can never grow unbounded. Email bodies are stored as plain text only (no heavy
// HTML) to keep storage small. Deduped on ghlMessageId so repeated syncs/backfills
// never create duplicate rows.
model ConversationMessage {
  id                String   @id @default(cuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ghlMessageId      String   @unique // HighLevel's own message id — dedupe key
  ghlConversationId String? // HighLevel's own conversation id — the reliable thread-grouping
  // fallback for messages missing a per-message contactId (e.g. system/automated
  // conversations); all messages fetched via one getMessages(convo.id) call share
  // this, so it's a safe grouping key even when contact identity is unknown.
  ghlContactId      String
  contactName       String?
  channel           String // "SMS" | "Email" | "Call" | "Voicemail"
  direction         String // "inbound" | "outbound"
  subject           String? // email subject only
  body              String   @db.Text // lean text body (no heavy HTML)
  ghlTimestamp      DateTime // when the message happened in HighLevel
  createdAt         DateTime @default(now())

  @@index([clientId, channel, ghlTimestamp])
  @@index([ghlContactId])
}

// A shared, running log of "what's the latest on this client" — e.g. summarizing
// an email that only landed in one person's inbox — so it's visible to the whole
// team instead of trapped in one person's mailbox. Mirrors the Comment model above.
model ClientNote {
  id        String      @id @default(cuid())
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String?
  author    TeamMember? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([clientId])
}

// A structured, per-meeting record distinct from ClientNote's free-text log:
// title/date/raw transcript plus an AI-generated structured summary. Fed
// manually today (paste a Fathom transcript in); FATHOM_WEBHOOK is reserved
// for when Fathom API/webhook access is confirmed, not wired up yet.
model MeetingNote {
  id          String            @id @default(cuid())
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId    String?
  author      TeamMember?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  title       String
  meetingDate DateTime
  transcript  String            @db.Text
  summary     String            @db.Text
  source      MeetingNoteSource @default(MANUAL)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([clientId])
}

// Tracks a client's landing page as a deliverable: status + where it lives.
// The page itself is built/hosted outside this app (a standalone static
// template kit pasted into GoHighLevel's Custom Code element) — this model
// only records status and pointers, mirroring the ClientNote pattern above.
model LandingPage {
  id              String            @id @default(cuid())
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status          LandingPageStatus @default(NOT_STARTED)
  ghlPageUrl      String? // the live page's URL inside GHL
  templateVersion String? // matches a tag/CHANGELOG entry in the template kit
  sourcePath      String? // path to clients/<client-slug>/ in the template kit repo
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([clientId])
}

model Task {
  id         String         @id @default(cuid())
  title      String
  assigneeId String?
  assignee   TeamMember?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  clientId   String? // null = internal/agency task, not tied to a client
  client     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  occurrence TaskOccurrence @default(NON_RECURRING)
  status     TaskStatus     @default(NEXT_UP)
  deadline   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  comments Comment[]
  links    TaskLink[]

  @@index([clientId])
  @@index([assigneeId])
  @@index([status])
}

model Comment {
  id        String      @id @default(cuid())
  taskId    String
  task      Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    TeamMember? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime    @default(now())

  @@index([taskId])
}

model TaskLink {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())

  @@index([taskId])
}

// Polymorphic activity feed entry — entityType/entityId point at whichever
// record the action happened to (Task, Client, TeamMember, ...). No FK to
// those tables since one log spans several unrelated models; entityLabel is
// denormalized so an entry still reads sensibly after the entity is deleted.
model ActivityLog {
  id          String      @id @default(cuid())
  actorId     String?
  actor       TeamMember? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorName   String?
  entityType  String
  entityId    String
  entityLabel String
  action      String
  description String
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// Per-recipient notification, fanned out from the same mutations ActivityLog
// records (task assignment/status/deadline changes, comments, @-mentions) —
// see src/lib/notify.ts. Unlike ActivityLog this is scoped to one person and
// tracks read state; readAt null = unread.
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   TeamMember       @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type        NotificationType
  entityType  String
  entityId    String
  entityLabel String
  message     String
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([recipientId, readAt])
  @@index([createdAt])
}

// Full snapshot of a Task at delete time. Denormalized on purpose (assigneeName/
// clientName as plain strings, not just FK ids) so a record stays meaningful even
// if the Client or TeamMember it referenced is later changed/deleted, and even
// read independent of the live relational DB (see archive durability mechanism
// in src/lib/archive.ts, which also mirrors this snapshot to Vercel Blob).
model ArchivedTask {
  id             String         @id @default(cuid())
  originalTaskId String
  title          String
  assigneeId     String?
  assigneeName   String?
  clientId       String?
  clientName     String?
  occurrence     TaskOccurrence
  status         TaskStatus
  deadline       DateTime?
  taskCreatedAt  DateTime
  taskUpdatedAt  DateTime
  deletedAt      DateTime       @default(now())
  deletedById    String?
  deletedBy      TeamMember?    @relation("ArchivedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  // Comments/TaskLink rows are hard-deleted (onDelete: Cascade) when the live
  // Task is deleted, so they're snapshotted here as plain JSON at archive time
  // — otherwise this backtracking history would be lost the moment a task is archived.
  comments Json?
  links    Json?

  @@index([originalTaskId])
}

// ---------------------------------------------------------------------------
// Asset Approval (Phase 2 prototype) — see "Feature: Asset Approval prototype"
// in the plan file. An Asset belongs to one Client and has one or more
// AssetVersions in chronological order. Reviewers (agency staff and/or guests
// via a share link) leave AssetComments (spatial pins on images, timecodes on
// video, per-page for PDF) and per-version AssetDecisions. Overall Asset.status
// is derived from those decisions.
// ---------------------------------------------------------------------------

model Asset {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  status      AssetStatus  @default(DRAFT)
  dueDate     DateTime?
  folderId    String?
  folder      AssetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   TeamMember?  @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  versions   AssetVersion[]
  reviewers  AssetReviewer[]
  shareLinks AssetShareLink[]

  @@index([clientId])
  @@index([status])
  @@index([folderId])
}

// A lightweight, per-client grouping for assets ("Q3 Campaign", "Website
// Redesign") — purely organizational, no workflow implications. Deleting a
// folder never deletes its assets (onDelete: SetNull on Asset.folderId),
// mirroring the same "detach, don't cascade-delete" choice already made for
// Task.assignee/Task.client.
model AssetFolder {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  assets Asset[]

  @@index([clientId])
}

// One revision of an asset. Exactly one of blobUrl / externalUrl is populated:
// blobUrl for uploaded files (bytes in Vercel Blob at assets/<clientId>/<assetId>/…),
// externalUrl for WEBSITE (a URL pasted in). versionNumber starts at 1 per asset
// and increments; comments/decisions attach per-version so uploading v2 preserves
// v1 feedback untouched.
model AssetVersion {
  id            String      @id @default(cuid())
  assetId       String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  versionNumber Int
  kind          AssetKind
  blobUrl       String?
  externalUrl   String?
  mimeType      String?
  sizeBytes     Int?
  uploadedById  String?
  uploadedBy    TeamMember? @relation("AssetVersionUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt    DateTime    @default(now())

  decisions AssetDecision[]
  comments  AssetComment[]

  @@unique([assetId, versionNumber])
  @@index([assetId])
}

// A reviewer assigned to an asset. Exactly one of teamMemberId (agency staff),
// clientUserId (a real client-login account, Slice 4b), or guestEmail
// (external guest via a tokenized share link, Slice 4a) is populated per row.
model AssetReviewer {
  id           String      @id @default(cuid())
  assetId      String
  asset        Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  teamMemberId String?
  teamMember   TeamMember? @relation("AssetReviewer", fields: [teamMemberId], references: [id], onDelete: SetNull)
  clientUserId String?
  clientUser   ClientUser? @relation("AssetReviewerClientUser", fields: [clientUserId], references: [id], onDelete: SetNull)
  guestEmail   String?
  guestName    String?
  createdAt    DateTime    @default(now())

  decisions AssetDecision[] @relation("ReviewerDecisions")
  comments  AssetComment[]  @relation("ReviewerComments")

  @@index([assetId])
  @@index([teamMemberId])
}

// A reviewer's decision on a specific version. One row per (versionId,
// reviewerId) — upserted; the latest decision replaces prior on the same
// version. Overall Asset.status is derived from these per-version rows.
model AssetDecision {
  id         String             @id @default(cuid())
  versionId  String
  version    AssetVersion       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   AssetReviewer      @relation("ReviewerDecisions", fields: [reviewerId], references: [id], onDelete: Cascade)
  decision   AssetDecisionValue
  note       String?            @db.Text
  decidedAt  DateTime           @default(now())

  @@unique([versionId, reviewerId])
  @@index([versionId])
}

// A comment on a specific version. `annotation` holds the markup shape (pin,
// rectangle, ellipse, arrow, pencil, or highlighter) as JSON:
// `{ type, color, points: [{x,y}, ...] }`, with all point coordinates stored
// as PERCENTAGES (0–100) of the media's rendered size — resolution/viewport
// independent, same principle the original pinX/pinY-only design used. A
// plain pin has one point; rectangle/ellipse/arrow have two (opposite
// corners, or start/end); pencil/highlighter have many (the traced path).
// pinX/pinY are kept for the handful of pre-annotation-toolbar rows created
// in Slice 2 (plain point pins, no `annotation`) — new rows always populate
// `annotation` instead and leave pinX/pinY null. page is 1-indexed for PDF
// (which doesn't support drawn markup — see AGENTS notes); timecodeMs is
// milliseconds for VIDEO, paired with `annotation` when a shape is drawn on a
// paused frame. parentId is a self-relation for threaded replies; resolvedAt
// marks resolved without deleting.
model AssetComment {
  id         String         @id @default(cuid())
  versionId  String
  version    AssetVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   AssetReviewer  @relation("ReviewerComments", fields: [reviewerId], references: [id], onDelete: Cascade)
  body       String         @db.Text
  pinX       Float? // legacy plain-pin coordinate (pre-annotation-toolbar rows only)
  pinY       Float?
  annotation Json? // { type: "pin"|"rectangle"|"ellipse"|"arrow"|"pencil"|"highlighter", color: string, points: {x:number,y:number}[] }
  timecodeMs Int?
  page       Int?
  parentId   String?
  parent     AssetComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    AssetComment[] @relation("CommentReplies")
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([versionId])
  @@index([parentId])
}

// A tokenized share link — a client can review the asset via /review/[token]
// without an account. passwordHash + expiresAt both optional (Ziflow parity).
// token is a 256-bit random value (see src/lib/share-link.ts) — the link IS
// the credential, so guessing it is not a realistic attack; failedPasswordAttempts
// + lockedUntil instead guard against brute-forcing a chosen link PASSWORD,
// which is a much smaller keyspace than the token itself.
model AssetShareLink {
  id                     String      @id @default(cuid())
  assetId                String
  asset                  Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  token                  String      @unique
  passwordHash           String?
  expiresAt              DateTime?
  failedPasswordAttempts Int         @default(0)
  lockedUntil            DateTime?
  createdById            String?
  createdBy              TeamMember? @relation("AssetShareLinkCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt              DateTime    @default(now())

  @@index([assetId])
}
